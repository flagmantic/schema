{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firstkindsoftware.com/declarative.schema.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "enum": [1]
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Project"
      }
    }
  },
  "additionalProperties": false,
  "required": ["version", "projects"],
  "$defs": {
    "Project": {
      "title": "Project",
      "type": "object",
      "required": ["name", "key", "feature_flags"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "description": {
          "type": ["string", "null"]
        },
        "tags": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          }
        },
        "feature_flags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FeatureFlag"
          }
        }
      }
    },
    "FeatureFlag": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": ["string", "null"]
        },
        "tags": {
          "type": ["array", "null"],
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          }
        },
        "variations": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[0-9]+$": {
              "$ref": "#/$defs/LabeledFlag"
            }
          },
          "additionalProperties": false
        },
        "is_frontend": {
          "type": "boolean"
        },
        "environments": {
          "$ref": "#/$defs/Environments"
        }
      },
      "required": ["environments", "is_frontend", "key", "name", "variations"],
      "title": "SchemaElement"
    },
    "Environments": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/Environment"
      },
      "required": ["development", "production", "staging"],
      "title": "Environments"
    },
    "Environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "targeting": {
          "type": ["array", "null"],
          "items": {
            "$ref": "#/$defs/Targeting"
          }
        },
        "enabled_default_variation": {
          "type": "integer"
        },
        "disabled_variation": {
          "type": "integer"
        }
      },
      "required": [
        "disabled_variation",
        "enabled",
        "enabled_default_variation"
      ],
      "title": "Environment"
    },
    "Targeting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "formula": {
          "$ref": "#/$defs/Formula"
        },
        "variation": {
          "type": "integer"
        },
        "starts_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["expires_at", "formula", "name", "starts_at", "variation"],
      "title": "Targeting"
    },
    "Formula": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "additionalProperties": false,
      "properties": {
        "Pure": {
          "$ref": "#/$defs/TargetingStrategy"
        },
        "And": {
          "type": "array",
          "prefixItems": [
            { "$ref": "#/$defs/Formula" },
            { "$ref": "#/$defs/Formula" }
          ],
          "items": false
        },
        "Or": {
          "type": "array",
          "prefixItems": [
            { "$ref": "#/$defs/Formula" },
            { "$ref": "#/$defs/Formula" }
          ],
          "items": false
        },
        "Negate": {
          "$ref": "#/$defs/Formula"
        }
      },
      "required": [],
      "title": "Formula"
    },
    "TargetingStrategy": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "MetadataPredicate": {
          "$ref": "#/$defs/MetadataPredicate"
        },
        "UserId": {
          "$ref": "#/$defs/UserID"
        },
        "Percentage": {
          "$ref": "#/$defs/Percentage"
        }
      },
      "required": [],
      "title": "TargetingStrategy"
    },
    "MetadataPredicate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attribute": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "operator": {
          "type": "string",
          "enum": ["StartsWith", "EndsWith", "Equals", "Contains", "Matches"]
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        }
      },
      "required": ["attribute", "operator", "value"],
      "title": "MetadataPredicate"
    },
    "UserID": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "user_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "integer"
          }
        }
      },
      "required": ["user_ids"],
      "title": "UserID"
    },
    "Percentage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "percentage": {
          "type": "number"
        }
      },
      "required": ["percentage"],
      "title": "Percentage"
    },
    "LabeledFlag": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "flag": {
          "$ref": "#/$defs/Flag"
        }
      },
      "required": ["flag", "label"],
      "title": "LabeledFlag"
    },
    "Flag": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "BooleanFlag": {
          "type": "boolean"
        },
        "JsonFlag": {
          "$ref": "#/$defs/JSONFlag"
        }
      },
      "required": [],
      "title": "Flag"
    },
    "JSONFlag": {
      "type": "object",
      "required": [],
      "title": "JSONFlag"
    }
  }
}
